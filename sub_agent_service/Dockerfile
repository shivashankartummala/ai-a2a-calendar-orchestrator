FROM python:3.11-slim

WORKDIR /app
COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY sub_agent_service /app/sub_agent_service
ENV PYTHONPATH=/app
EXPOSE 8001

CMD ["uvicorn", "sub_agent_service.app.main:app", "--host", "0.0.0.0", "--port", "8001"]
