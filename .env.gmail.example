# ===== Master Agent =====
MASTER_HOST=0.0.0.0
MASTER_PORT=8000
GOOGLE_AGENT_BASE_URL=http://google_agent_service:8001
OUTLOOK_AGENT_BASE_URL=http://outlook_agent_service:8001
USE_LLM_PLANNER=false
LITELLM_MODEL=claude-3-5-sonnet-20241022
HTTP_TIMEOUT_SECONDS=10

# ===== Google Provider Agent =====
GOOGLE_SUB_AGENT_HOST=0.0.0.0
GOOGLE_SUB_AGENT_PORT=8001
GOOGLE_PROVIDER_TYPE=google
GOOGLE_MCP_BASE_URL=http://mcp_calendar_server:8002

# ===== Outlook Provider Agent (kept running, unused in gmail-only test) =====
OUTLOOK_SUB_AGENT_HOST=0.0.0.0
OUTLOOK_SUB_AGENT_PORT=8001
OUTLOOK_PROVIDER_TYPE=outlook
OUTLOOK_MCP_BASE_URL=http://mcp_calendar_server:8002

# ===== MCP Server =====
MCP_HOST=0.0.0.0
MCP_PORT=8002
MCP_MOCK_MODE=false

# ===== Google Live Adapter =====
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_DEFAULT_TIMEZONE=America/Los_Angeles

# User ID used by master/sub-agent for final booking authority
GOOGLE_BOOKING_USER_ID=A

# Fallbacks (optional if all users configured below)
GOOGLE_FALLBACK_CALENDAR_ID=primary
GOOGLE_FALLBACK_REFRESH_TOKEN=

# IMPORTANT: keep this as one single-line JSON string
GOOGLE_USER_CONFIG_JSON={"A":{"calendar_id":"primary","refresh_token":"paste-refresh-token-for-a@gmail.com","email":"a@gmail.com"},"B":{"calendar_id":"primary","refresh_token":"paste-refresh-token-for-b@gmail.com","email":"b@gmail.com"},"C":{"calendar_id":"primary","refresh_token":"paste-refresh-token-for-c@gmail.com","email":"c@gmail.com"}}

# ===== Unused for gmail-only test =====
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=
OUTLOOK_REFRESH_TOKEN=
