# Master agent
MASTER_HOST=0.0.0.0
MASTER_PORT=8000
GOOGLE_AGENT_BASE_URL=http://google_agent_service:8001
OUTLOOK_AGENT_BASE_URL=http://outlook_agent_service:8001
USE_LLM_PLANNER=false
LITELLM_MODEL=claude-3-5-sonnet-20241022
HTTP_TIMEOUT_SECONDS=10

# Google provider agent
GOOGLE_SUB_AGENT_HOST=0.0.0.0
GOOGLE_SUB_AGENT_PORT=8001
GOOGLE_PROVIDER_TYPE=google
GOOGLE_MCP_BASE_URL=http://mcp_calendar_server:8002

# Outlook provider agent
OUTLOOK_SUB_AGENT_HOST=0.0.0.0
OUTLOOK_SUB_AGENT_PORT=8001
OUTLOOK_PROVIDER_TYPE=outlook
OUTLOOK_MCP_BASE_URL=http://mcp_calendar_server:8002

# MCP server
MCP_HOST=0.0.0.0
MCP_PORT=8002
MCP_MOCK_MODE=true

# Production placeholders (when replacing mock adapters)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=
OUTLOOK_REFRESH_TOKEN=
